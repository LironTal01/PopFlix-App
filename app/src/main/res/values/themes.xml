<!-- App theme definitions -->
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Base.Theme.PopiFlix" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here -->
        <item name="colorPrimary">@color/light_main_color</item>
        <item name="colorOnPrimary">@color/light_main_text_color</item>
        
        <!-- Set white backgrounds for light theme -->
        <item name="android:windowBackground">@color/light_background_color</item>
        <item name="colorSurface">@color/light_background_color</item>
        <item name="colorSurfaceVariant">@color/light_secondary_background</item>
        <item name="colorOnSurface">@color/light_text_color</item>
        <item name="colorOnSurfaceVariant">@color/light_secondary_text_color</item>
        
        <!-- Ensure proper text colors for light theme -->
        <item name="android:textColorPrimary">@color/light_text_color</item>
        <item name="android:textColorSecondary">@color/light_secondary_text_color</item>
        
        <!-- Status bar and navigation bar colors for light theme -->
        <item name="android:statusBarColor">@color/light_background_color</item>
        <item name="android:navigationBarColor">@color/light_background_color</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.PopiFlix" parent="Base.Theme.PopiFlix" />
    
    <!-- Style for rounded poster corners -->
    <style name="RoundedPoster">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">32dp</item>
    </style>
    
    <!-- Style for small rounded poster corners -->
    <style name="RoundedPosterSmall">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    
    <!-- Style for toolbar title -->
    <style name="ToolbarTitleStyle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>
    
    <!-- Style for search box with thicker border -->
    <style name="SearchBoxStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeWidth">3dp</item>
        <item name="boxStrokeWidthFocused">4dp</item>
    </style>

    <!-- Style to remove ripple effect from navigation items -->
    <style name="NoRippleStyle" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@android:color/transparent</item>
        <item name="android:width">0dp</item>
        <item name="android:height">0dp</item>
    </style>
</resources>